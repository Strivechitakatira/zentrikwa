# ═══════════════════════════════════════════════════════════════════════════════
# Conva — Root .env.example
# Copy to .env and fill in values for local development.
#
# Each sub-project also has its own .env.example:
#   backend/.env.example   ← all backend secrets (loaded by docker-compose)
#   frontend/.env.example  ← frontend env vars (copy to frontend/.env.local)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # BACKEND ONLY
SUPABASE_JWT_SECRET=                # Supabase → Settings → API → JWT Secret

# ─── Meta WhatsApp Cloud API ──────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_EMBEDDED_SIGNUP_CONFIG_ID=

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                  # BACKEND ONLY

# ─── Queue / Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
QSTASH_TOKEN=                       # BACKEND ONLY
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ─── Payments ─────────────────────────────────────────────────────────────────
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
STRIPE_SECRET_KEY=                  # BACKEND ONLY
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=                     # BACKEND ONLY

# ─── Security ─────────────────────────────────────────────────────────────────
ENCRYPTION_SECRET=                  # ≥32 chars
INTERNAL_API_SECRET=
CRON_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Conva
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000
DEBUG=true
