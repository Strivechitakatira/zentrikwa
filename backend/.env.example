# ─── Required — app will NOT start if any of these are missing ────────────────

SECRET_KEY=                             # ≥32 chars in production; AES key + signing
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=              # BACKEND ONLY — bypasses RLS
JWT_SECRET=                             # Supabase → Settings → API → JWT Secret
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
ANTHROPIC_API_KEY=                      # BACKEND ONLY
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=              # Your chosen random string

# ─── Optional — defaults shown ────────────────────────────────────────────────

APP_NAME=Zentrikai
DEBUG=true                              # Must be false in production
ENVIRONMENT=development                 # development | staging | production
JWT_ALGORITHM=HS256
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000   # Comma-separated list in production

# ─── Payments (leave empty if not configured) ─────────────────────────────────

PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
STRIPE_SECRET_KEY=                      # BACKEND ONLY
STRIPE_WEBHOOK_SECRET=

# ─── Email ────────────────────────────────────────────────────────────────────

RESEND_API_KEY=                         # BACKEND ONLY
